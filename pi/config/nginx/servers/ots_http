# BigMacATAK — HTTP server (ports 80 + 8080)
server {
    # Redirect HTTP/80 to HTTPS
    if ($server_port = 80) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    listen 8080 default_server;
    listen [::]:8080 default_server;

    root /var/www/opentakserver;
    index index.html;
    server_name bigmacatak_8080;

    # API and Marti endpoints go to OTS backend
    location ~ ^/(api|Marti) {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
    }

    # WebSocket for Socket.IO
    location /socket.io {
        proxy_pass http://127.0.0.1:8081/socket.io;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
    }

    # WebRTC proxy (MediaMTX)
    location ~ ^/webrtc(/?)(.*)$ {
        proxy_pass https://127.0.0.1:8889/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # HLS proxy (MediaMTX)
    location ~ ^/hls(/?)(.*)$ {
        proxy_pass https://127.0.0.1:8888/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Static files + SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    client_max_body_size 100M;
}
