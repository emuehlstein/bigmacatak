# BigMacATAK — HTTPS server (port 443) + Marti API (port 8443)

# Port 443 — Web UI with SSL (no Marti API)
server {
    root /var/www/opentakserver;
    index index.html index.htm;
    server_name bigmacatak_443;

    location ~ ^/Marti {
        return 404;
    }

    location ~ ^/webrtc(/?)(.*)$ {
        proxy_pass https://127.0.0.1:8889/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location ~ ^/hls(/?)(.*)$ {
        proxy_pass https://127.0.0.1:8888/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /api {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host:443;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Ssl-Cert $ssl_client_escaped_cert;
    }

    location /socket.io {
        include proxy_params;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_pass http://127.0.0.1:8081/socket.io;
    }

    try_files $uri /index.html;
    client_max_body_size 100M;

    listen 443 ssl;
    ssl_certificate __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.pem;
    ssl_certificate_key __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.nopass.key;
}

# Port 8443 — Marti API with client cert verification
server {
    root /var/www/opentakserver;
    index index.html index.htm;
    server_name bigmacatak_8443;

    location /Marti/api/tls {
        return 404;
    }

    location /Marti {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Ssl-Cert $ssl_client_escaped_cert;
    }

    location /api {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host:8443;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Ssl-Cert $ssl_client_escaped_cert;
    }

    location /files {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host:443;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Ssl-Cert $ssl_client_escaped_cert;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 100M;

    listen 8443 ssl;
    ssl_certificate __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.pem;
    ssl_certificate_key __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.nopass.key;

    ssl_verify_client on;
    ssl_client_certificate __BIGMAC_DATA__/ca/ca.pem;
}
