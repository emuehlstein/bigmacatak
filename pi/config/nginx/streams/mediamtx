# SSL Proxy for MediaMTX RTSP (8322 → 8554) and RTMP (1936 → 1935)

# RTSP
server {
    listen     8322 ssl;
    proxy_pass 127.0.0.1:8554;

    ssl_certificate __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.pem;
    ssl_certificate_key __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.nopass.key;
}

# RTMP
server {
    listen     1936 ssl;
    proxy_pass 127.0.0.1:1935;

    ssl_certificate __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.pem;
    ssl_certificate_key __BIGMAC_DATA__/ca/certs/opentakserver/opentakserver.nopass.key;
}
