[Unit]
Description=OTS CoT Parser
After=opentakserver.service rabbitmq-server.service
Requires=rabbitmq-server.service

[Service]
Type=simple
User=__BIGMAC_USER__
WorkingDirectory=__BIGMAC_DATA__
ExecStart=__BIGMAC_VENV__/bin/cot_parser
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
